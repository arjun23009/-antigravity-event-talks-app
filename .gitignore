.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing it locally, it is ignored here as virtualenvs might differ
#   Feel free to comment this if you want to include it.
#Lockfile
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is usually recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is usually recommended to be committed.
#pdm.lock

# PEP 582; project local packages directory (used by pdm)
